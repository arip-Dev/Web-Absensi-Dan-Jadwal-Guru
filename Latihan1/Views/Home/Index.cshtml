@{
    ViewData["Title"] = "Sistem Penjadwalan guru";
    ViewData["HideSidebar"] = true;
    ViewData["HideFooter"] = true;
}

<style>
    /* Smooth scroll di seluruh dokumen */
    html {
        scroll-behavior: smooth;
    }
</style>

<!-- NAVBAR (sticky) -->
<header id="topbar" class="sticky top-0 z-50 border-b border-gray-200 bg-white/80 backdrop-blur">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3">
        <!-- Brand -->
        <a href="#hero" class="group flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-blue-600 text-white shadow-sm">
                <!-- Logo/placeholder -->
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transition-transform group-hover:rotate-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 6v12m6-6H6" />
                </svg>
            </div>
            <div>
                <div class="text-base font-semibold leading-tight text-gray-900">Schedulify School</div>
                <div class="text-xs -mt-0.5 text-gray-500">Penjadwalan & Penilaian guru</div>
            </div>
        </a>

        <!-- Nav desktop -->
        <nav class="hidden items-center gap-6 md:flex">
            <a href="#hero" class="navlink text-sm font-medium text-gray-700 hover:text-gray-900">Beranda</a>
            <a href="#features" class="navlink text-sm font-medium text-gray-700 hover:text-gray-900">Fitur</a>
            <a href="#modules" class="navlink text-sm font-medium text-gray-700 hover:text-gray-900">Modul</a>
            <a href="#about" class="navlink text-sm font-medium text-gray-700 hover:text-gray-900">Tentang</a>
            <a href="#contact" class="navlink text-sm font-medium text-gray-700 hover:text-gray-900">Kontak</a>
            <a asp-controller="Auth" asp-action="Login"
               class="inline-flex items-center rounded-xl bg-gray-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900/60">
                Login
            </a>
        </nav>

        <!-- Toggle mobile -->
        <button type="button" id="btnMobile"
                class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-gray-200 text-gray-700 md:hidden">
            <svg id="iconOpen" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M4 6h16M4 12h16M4 18h16" /></svg>
            <svg id="iconClose" xmlns="http://www.w3.org/2000/svg" class="hidden h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
    </div>

    <!-- Nav mobile -->
    <nav id="mobileMenu" class="hidden border-t border-gray-200 bg-white md:hidden">
        <div class="mx-auto grid max-w-7xl gap-1 px-4 py-3">
            <a href="#hero" class="moblink rounded-lg px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">Beranda</a>
            <a href="#features" class="moblink rounded-lg px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">Fitur</a>
            <a href="#modules" class="moblink rounded-lg px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">Modul</a>
            <a href="#about" class="moblink rounded-lg px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">Tentang</a>
            <a href="#contact" class="moblink rounded-lg px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">Kontak</a>
            <a asp-controller="Auth" asp-action="Login"
               class="mt-1 inline-flex items-center justify-center rounded-xl bg-gray-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-gray-800">
                Login
            </a>
        </div>
    </nav>
</header>

<!-- HERO -->
<section id="hero" class="scroll-mt-28 bg-gray-50">
    <div class="mx-auto grid max-w-7xl grid-cols-1 items-center gap-10 px-4 py-14 md:py-20 lg:grid-cols-2 lg:gap-14">
        <div>
            <span class="inline-flex items-center gap-2 rounded-full border border-blue-200 bg-blue-50 px-3 py-1 text-xs font-medium text-blue-700">
                Solusi Sekolah • Siap dikembangkan ke Penilaian
            </span>
            <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-gray-900 sm:text-5xl">
                Kelola jadwal guru dengan <span class="text-blue-600">Cepat</span> & <span class="text-blue-600">Rapi</span>
            </h1>
            <p class="mt-4 max-w-xl text-gray-600">
                Platform untuk mengatur jadwal mengajar, alokasi ruang, hingga rekap presensi.
                Ke depan, modul penilaian dan pelaporan akan terintegrasi dalam satu sistem.
            </p>
            <div class="mt-6 flex flex-wrap items-center gap-3">
                <a asp-controller="Auth" asp-action="Login"
                   class="inline-flex items-center rounded-xl bg-gray-900 px-5 py-3 font-semibold text-white hover:bg-gray-800">
                    mulai Sekarang
                </a>
                <a href="#features" class="inline-flex items-center rounded-xl border border-gray-300 bg-white px-5 py-3 font-semibold text-gray-900 hover:bg-gray-50">
                    Lihat Fitur
                </a>
            </div>
        </div>
        <div>
            <div class="rounded-2xl border border-gray-200 bg-white p-3 shadow-sm">
                <img src="https://images.unsplash.com/photo-1523580846011-d3a5bc25702b?q=80&w=1600&auto=format&fit=crop"
                     alt="Ilustrasi Penjadwalan"
                     class="h-[280px] w-full rounded-xl object-cover sm:h-[360px]" />
            </div>
            <p class="mt-3 text-xs text-gray-500">Ilustrasi sistem penjadwalan modern yang simple & powerful.</p>
        </div>
    </div>
</section>

<!-- FEATURES -->
<section id="features" class="scroll-mt-28 bg-white">
    <div class="mx-auto max-w-7xl px-4 py-14 md:py-20">
        <div class="mb-8 text-center">
            <h2 class="text-3xl font-bold text-gray-900">Fitur Utama</h2>
            <p class="mt-2 text-gray-600">Dirancang untuk kebutuhan sekolah yang dinamis dan berkembang.</p>
        </div>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            <!-- Card -->
            <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
                <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-blue-50 text-blue-600">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor"><path d="M6 2h9l5 5v13a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2Z" /></svg>
                </div>
                <h3 class="text-lg font-semibold text-gray-900">Penjadwalan Otomatis</h3>
                <p class="mt-1 text-gray-600">Susun jadwal berdasarkan ketersediaan guru, mata pelajaran, dan ruang kelas.</p>
            </div>

            <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
                <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor"><path d="M12 12a5 5 0 1 0-5-5 5.006 5.006 0 0 0 5 5Zm6 8.25A7.5 7.5 0 0 0 4.5 20.25a.75.75 0 0 1-1.5 0A9 9 0 0 1 21 20.25a.75.75 0 0 1-1.5 0Z" /></svg>
                </div>
                <h3 class="text-lg font-semibold text-gray-900">Portal guru</h3>
                <p class="mt-1 text-gray-600">guru melihat jadwal pribadi, presensi, dan informasi pengajaran.</p>
            </div>

            <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
                <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-amber-50 text-amber-600">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor"><path d="M4 4h16v2H4zm0 7h16v2H4zm0 7h16v2H4z" /></svg>
                </div>
                <h3 class="text-lg font-semibold text-gray-900">Rencana Pengembangan</h3>
                <p class="mt-1 text-gray-600">Modul penilaian & reporting terpadu dalam peta jalan produk.</p>
            </div>
        </div>
    </div>
</section>

<!-- MODULES / CAPABILITIES -->
<section id="modules" class="scroll-mt-28 bg-gray-50">
    <div class="mx-auto max-w-7xl px-4 py-14 md:py-20">
        <div class="mb-8 text-center">
            <h2 class="text-3xl font-bold text-gray-900">Modul & Kapabilitas</h2>
            <p class="mt-2 text-gray-600">Fondasi untuk operasi akademik yang lebih efektif.</p>
        </div>

        <div class="grid gap-6 lg:grid-cols-3">
            <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
                <h3 class="text-lg font-semibold text-gray-900">Data Master</h3>
                <ul class="mt-2 list-disc pl-5 text-gray-600">
                    <li>guru, Mata Pelajaran, kelas/Ruang</li>
                    <li>Kuota jam & ketersediaan</li>
                    <li>Kalender akademik</li>
                </ul>
            </div>

            <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
                <h3 class="text-lg font-semibold text-gray-900">Engine jadwal</h3>
                <ul class="mt-2 list-disc pl-5 text-gray-600">
                    <li>Aturan bentrok & preferensi</li>
                    <li>Penempatan otomatis & manual</li>
                    <li>Versi & riwayat perubahan</li>
                </ul>
            </div>

            <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
                <h3 class="text-lg font-semibold text-gray-900">Akses & Laporan</h3>
                <ul class="mt-2 list-disc pl-5 text-gray-600">
                    <li>Portal Admin & guru</li>
                    <li>Ekspor PDF/Excel</li>
                    <li>Integrasi SSO (opsional)</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- ABOUT -->
<section id="about" class="scroll-mt-28 bg-white">
    <div class="mx-auto grid max-w-7xl grid-cols-1 items-center gap-10 px-4 py-14 md:py-20 lg:grid-cols-2">
        <div>
            <h2 class="text-3xl font-bold text-gray-900">Tentang Kami</h2>
            <p class="mt-3 text-gray-600">
                Schedulify School adalah tim pengembang edtech yang fokus pada efisiensi operasional sekolah.
                Kami berkomitmen menghadirkan solusi terukur yang mudah digunakan guru dan admin.
            </p>
            <div class="mt-5 grid grid-cols-3 gap-4">
                <div class="rounded-2xl border border-gray-200 bg-gray-50 p-4 text-center">
                    <div class="text-2xl font-extrabold text-gray-900">50+</div>
                    <div class="text-xs text-gray-500">Sekolah Uji Coba</div>
                </div>
                <div class="rounded-2xl border border-gray-200 bg-gray-50 p-4 text-center">
                    <div class="text-2xl font-extrabold text-gray-900">99.9%</div>
                    <div class="text-xs text-gray-500">Uptime Target</div>
                </div>
                <div class="rounded-2xl border border-gray-200 bg-gray-50 p-4 text-center">
                    <div class="text-2xl font-extrabold text-gray-900">2025</div>
                    <div class="text-xs text-gray-500">Roadmap Penilaian</div>
                </div>
            </div>
        </div>
        <div>
            <div class="rounded-2xl border border-gray-200 bg-white p-3 shadow-sm">
                <img src="https://images.unsplash.com/photo-1553877522-43269d4ea984?q=80&w=1600&auto=format&fit=crop"
                     alt="Tentang Kami"
                     class="h-[280px] w-full rounded-xl object-cover sm:h-[360px]" />
            </div>
        </div>
    </div>
</section>

<!-- CONTACT / CTA -->
<section id="contact" class="scroll-mt-28 bg-gray-50">
    <div class="mx-auto max-w-7xl px-4 py-14 md:py-20">
        <div class="mb-8 text-center">
            <h2 class="text-3xl font-bold text-gray-900">Hubungi Kami</h2>
            <p class="mt-2 text-gray-600">Tertarik mencoba? Dapatkan demo atau konsultasi gratis.</p>
        </div>

        <div class="mx-auto max-w-2xl rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
            <form class="grid grid-cols-1 gap-4 md:grid-cols-2">
                <div>
                    <label class="mb-1 block text-sm font-medium text-gray-700">nama Lengkap</label>
                    <input type="text" class="block w-full rounded-xl border border-gray-300 px-3 py-2 focus:border-gray-900 focus:outline-none focus:ring-2 focus:ring-gray-900" placeholder="nama Anda" />
                </div>
                <div>
                    <label class="mb-1 block text-sm font-medium text-gray-700">email</label>
                    <input type="email" class="block w-full rounded-xl border border-gray-300 px-3 py-2 focus:border-gray-900 focus:outline-none focus:ring-2 focus:ring-gray-900" placeholder="email@sekolah.ac.id" />
                </div>
                <div class="md:col-span-2">
                    <label class="mb-1 block text-sm font-medium text-gray-700">Pesan</label>
                    <textarea rows="4" class="block w-full rounded-xl border border-gray-300 px-3 py-2 focus:border-gray-900 focus:outline-none focus:ring-2 focus:ring-gray-900" placeholder="Ceritakan kebutuhan sekolah Anda..."></textarea>
                </div>
                <div class="md:col-span-2">
                    <button type="button" class="inline-flex w-full items-center justify-center rounded-xl bg-gray-900 px-5 py-3 font-semibold text-white hover:bg-gray-800">
                        Kirim Pesan
                    </button>
                </div>
            </form>

            <p class="mt-3 text-center text-xs text-gray-500">Atau hubungi kami via email: support@schedulify.school</p>
        </div>

        <div class="mt-10 text-center">
            <a asp-controller="Auth" asp-action="Login"
               class="inline-flex items-center rounded-xl border border-gray-300 bg-white px-5 py-3 font-semibold text-gray-900 hover:bg-gray-50">
                Masuk • Admin / guru
            </a>
        </div>
    </div>
</section>

<!-- FOOTER -->
<footer class="border-t border-gray-200 bg-white">
    <div class="mx-auto max-w-7xl px-4 py-6 text-center text-sm text-gray-500">
        © @DateTime.Now.Year Schedulify School — Semua hak dilindungi.
    </div>
</footer>

@section Scripts {
    <script>
        // Toggle mobile menu
        const btn = document.getElementById('btnMobile');
        const menu = document.getElementById('mobileMenu');
        const icoOpen = document.getElementById('iconOpen');
        const icoClose = document.getElementById('iconClose');

        btn?.addEventListener('click', () => {
          const shown = !menu.classList.contains('hidden');
          menu.classList.toggle('hidden', shown);
          icoOpen.classList.toggle('hidden', !shown);
          icoClose.classList.toggle('hidden', shown);
        });

        // Close mobile menu after clicking a link
        document.querySelectorAll('#mobileMenu a.moblink').forEach(a => {
          a.addEventListener('click', () => {
            menu.classList.add('hidden');
            icoOpen.classList.remove('hidden');
            icoClose.classList.add('hidden');
          });
        });

        // Highlight active nav link saat scroll
        const sections = ['hero','features','modules','about','contact'];
        const links = [...document.querySelectorAll('.navlink')];

        const io = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              links.forEach(l => l.classList.remove('text-gray-900'));
              const id = entry.target.id;
              const active = links.find(l => l.getAttribute('href') === '#' + id);
              active?.classList.add('text-gray-900');
            }
          });
        }, { rootMargin: '-30% 0px -60% 0px', threshold: 0.1 });

        sections.forEach(id => {
          const el = document.getElementById(id);
          if (el) io.observe(el);
        });
    </script>
}
