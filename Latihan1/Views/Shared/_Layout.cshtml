@{
    bool hideSidebar = ViewData["HideSidebar"] as bool? ?? false;
    bool hideFooter = ViewData["HideFooter"] as bool? ?? false;

    string? curController = ViewContext.RouteData.Values["controller"]?.ToString();
    string? curAction = ViewContext.RouteData.Values["action"]?.ToString();

    // helper class item
    Func<bool, string> itemClass = (bool isActive) =>
        isActive
            ? "flex items-center gap-3 rounded-2xl px-4 py-3 bg-blue-600 text-white shadow-md shadow-blue-200"
            : "flex items-center gap-3 rounded-2xl px-4 py-3 text-slate-600 hover:bg-slate-50";

    Func<bool, string> iconWrap = (bool active) =>
        active ? "h-5 w-5 text-white" : "h-5 w-5 text-slate-500";

    // === menu aktif ===
    bool activeDashboard =
        string.Equals(curController, "Admin", StringComparison.OrdinalIgnoreCase) &&
        string.Equals(curAction, "Admin_page", StringComparison.OrdinalIgnoreCase);

    bool activeTeachers =
        string.Equals(curController, "Dataguru", StringComparison.OrdinalIgnoreCase) &&
        (
            string.Equals(curAction, "Teacher_data", StringComparison.OrdinalIgnoreCase) || // list
            string.Equals(curAction, "Create", StringComparison.OrdinalIgnoreCase) || // form tambah
            string.Equals(curAction, "Edit", StringComparison.OrdinalIgnoreCase)    // form edit
        );

    bool activeSubjects =
    (string.Equals(curController, "Mapel", StringComparison.OrdinalIgnoreCase) &&
     string.Equals(curAction, "Index", StringComparison.OrdinalIgnoreCase))
    ||
    (string.Equals(curController, "Mapel", StringComparison.OrdinalIgnoreCase) &&
     string.Equals(curAction, "Index", StringComparison.OrdinalIgnoreCase)); // kalau masih mau dukung halaman lama


    bool activeKelas =
        string.Equals(curController, "Kelas", StringComparison.OrdinalIgnoreCase) &&
        string.Equals(curAction, "Index", StringComparison.OrdinalIgnoreCase);

    bool activeSchedules =
        string.Equals(curController, "Home", StringComparison.OrdinalIgnoreCase) &&
        string.Equals(curAction, "BuatJadwal", StringComparison.OrdinalIgnoreCase);

    bool activeReports =
        string.Equals(curController, "Home", StringComparison.OrdinalIgnoreCase) &&
        string.Equals(curAction, "Laporan", StringComparison.OrdinalIgnoreCase);
}

<!DOCTYPE html>
<html lang="id" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@(ViewData["Title"] ?? "Latihan1")</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="min-h-screen bg-gray-50 text-gray-900 antialiased flex overflow-x-hidden">
    <!-- tombol burger (mobile) -->
    <button id="openSidebarBtn"
            class="fixed top-3 left-3 z-30 lg:hidden rounded-lg p-2 bg-white/90 border border-slate-200 shadow hover:bg-white"
            aria-label="Buka sidebar" aria-controls="sidebar" aria-expanded="false">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-700" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
    </button>

    @* SIDEBAR *@
    @if (!hideSidebar)
    {
        <aside id="sidebar"
               class="fixed inset-y-0 left-0 z-40 w-72 border-r border-slate-200 bg-white p-4 transform transition-transform duration-200 -translate-x-full lg:translate-x-0 flex flex-col"
               aria-hidden="true">
            <div id="sidebarHeader" class="flex items-center justify-between">
                <div id="brandBlock" class="flex items-center gap-2 collapse-hide">
                    <div class="h-9 w-9 rounded-xl bg-indigo-600"></div>
                    <span class="text-lg font-semibold tracking-tight">Admin Panel</span>
                </div>

                <!-- tombol collapse/expand -->
                <button id="collapseHeaderBtn" class="hidden lg:inline-flex rounded-lg p-2 hover:bg-gray-100" aria-label="Toggle sidebar">
                    <!-- Expanded: chevron-left -->
                    <svg id="icCollapse" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                    <!-- Collapsed: chevron-right -->
                    <svg id="icExpand" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </button>

                <button id="closeSidebarBtn" class="lg:hidden rounded-lg p-2 hover:bg-gray-100" aria-label="Tutup sidebar">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path d="M6 18 18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

            <nav class="mt-6 space-y-2">
                <a asp-controller="Admin" asp-action="Admin_page" class="@itemClass(activeDashboard)">
                    <svg xmlns="http://www.w3.org/2000/svg" class="@iconWrap(activeDashboard)" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M3 3h8v8H3V3zm10 0h8v5h-8V3zM3 13h5v8H3v-8zm10 5h8v3h-8v-3z" />
                    </svg>
                    <span class="font-medium nav-label">Dashboard</span>
                </a>

                <a asp-controller="Dataguru" asp-action="Teacher_data" class="@itemClass(activeTeachers)">
                    <svg xmlns="http://www.w3.org/2000/svg" class="@iconWrap(activeTeachers)" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 12a5 5 0 100-10 5 5 0 000 10z" />
                        <path d="M4 22a8 8 0 0116 0H4z" />
                    </svg>
                    <span class="font-medium nav-label">Data Guru</span>
                </a>

                <a asp-controller="Mapel" asp-action="Index" class="@itemClass(activeSubjects)">
                    <svg xmlns="http://www.w3.org/2000/svg" class="@iconWrap(activeSubjects)" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M5 4h14v2H5zM5 9h14v2H5zM5 14h14v2H5zM5 19h14v2H5z" />
                    </svg>
                    <span class="font-medium nav-label">Mata Pelajaran</span>
                </a>

                <a asp-controller="Kelas" asp-action="Index" class="@itemClass(activeKelas)">
                    <svg xmlns="http://www.w3.org/2000/svg" class="@iconWrap(activeKelas)" viewBox="0 0 500 500"fill="currentColor">
                        <path d="M32 64C32 28.7 60.7 0 96 0L352 0c35.3 0 64 28.7 64 64l0 384c17.7 0 32 14.3 32 32s-14.3 32-32 32L32 512c-17.7 0-32-14.3-32-32s14.3-32 32-32L32 64zM320 288a32 32 0 1 0 0-64 32 32 0 1 0 0 64z" />
                        </svg>
                    <span class="font-medium nav-label">Kelas</span>
                </a>

                <a asp-controller="BuatJadwal" asp-action="BuatJadwal" class="@itemClass(activeSchedules)">
                    <svg xmlns="http://www.w3.org/2000/svg" class="@iconWrap(activeSchedules)" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M7 2a1 1 0 011 1v1h8V3a1 1 0 112 0v1h2a1 1 0 011 1v3H2V5a1 1 0 011-1h2V3a1 1 0 112 0v1zm15 7v10a2 2 0 01-2 2H4a2 2 0 01-2-2V9h20z" />
                    </svg>
                    <span class="font-medium nav-label">Buat Jadwal</span>
                </a>

                <a asp-controller="Reports" asp-action="Laporan" class="@itemClass(activeReports)">
                    <svg xmlns="http://www.w3.org/2000/svg" class="@iconWrap(activeReports)" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M5 3h14a2 2 0 012 2v14l-4-3-4 3-4-3-4 3V5a2 2 0 012-2z" />
                    </svg>
                    <span class="font-medium nav-label">Laporan</span>
                </a>
            </nav>

            <div class="mt-8 rounded-2xl border border-slate-200 p-4 collapse-hide">
                <p class="text-sm text-slate-600">Tahun Ajaran</p>
                <div class="mt-1 flex items-center justify-between">
                    <span class="font-medium">2025 / 2026</span>
                    <button class="rounded-lg px-2 py-1 text-sm hover:bg-slate-50">Ubah</button>
                </div>
            </div>

            <div class="mt-auto"></div>

            <a asp-controller="Auth" asp-action="GoToAbsensi"
               class="mt-4 flex items-center gap-3 w-full rounded-2xl border border-indigo-100 bg-white px-4 py-3 font-medium text-indigo-600 shadow-sm hover:bg-indigo-50 hover:shadow-md transition-all duration-200 group">

                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 min-w-[1.25rem] text-indigo-500 group-hover:text-indigo-700 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                </svg>

                <div class="flex flex-col text-left nav-label">
                    <span class="leading-none">Aplikasi Absensi</span>
                </div>

                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-auto text-indigo-300 nav-label" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
            </a>

            <a asp-controller="Auth" asp-action="Logout"
               class="mt-4 inline-flex items-center gap-2 rounded-2xl border border-red-200 bg-white px-4 py-3 font-medium text-red-600 hover:bg-red-50 transition">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M16 13v-2H7V8l-5 4 5 4v-3h9zM20 3h-8v2h8v14h-8v2h8a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2z" />
                </svg>
                <span class="font-medium nav-label">Keluar</span>
            </a>
        </aside>
    }

    <!-- KONTEN -->
    <div id="contentWrap" class="flex-1 @(hideSidebar ? "" : "lg:pl-72")">
        <main role="main">@RenderBody()</main>

        @if (!hideFooter)
        {
            <footer class="mt-auto border-t border-slate-200 bg-white">
                <div class="mx-auto max-w-7xl px-4 py-6 text-sm text-slate-600">
                    &copy; @DateTime.Now.Year — Latihan1.
                    <a asp-controller="Home" asp-action="Privacy" class="ml-2 underline hover:text-indigo-600">Kebijakan Privasi</a>
                </div>
            </footer>
        }
    </div>

    <div id="sidebarBackdrop" class="fixed inset-0 z-30 bg-black/30 opacity-0 pointer-events-none lg:hidden transition-opacity"></div>

    <!-- Script aman -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"
            integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo="
            crossorigin="anonymous"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
          const el = {
            sidebar:     document.getElementById('sidebar'),
            content:     document.getElementById('contentWrap'),
            header:      document.getElementById('sidebarHeader'),
            collapseBtn: document.getElementById('collapseHeaderBtn'),
            icCollapse:  document.getElementById('icCollapse'),
            icExpand:    document.getElementById('icExpand'),
            openBtn:     document.getElementById('openSidebarBtn'),
            closeBtn:    document.getElementById('closeSidebarBtn'),
            backdrop:    document.getElementById('sidebarBackdrop')
          };

          if (!el.sidebar || !el.content) return;

          const LS_KEY = 'sidebarCollapsed';
          const isDesktop = () => window.innerWidth >= 1024; // lg

          function swapClass(node, fromC, toC) {
            if (!node) return;
            if (node.classList.contains(fromC)) node.classList.replace(fromC, toC);
            else node.classList.add(toC);
          }

          function applyCollapsedUI(collapsed) {
            if (collapsed) {
              swapClass(el.sidebar, 'w-72', 'w-20');
              swapClass(el.content, 'lg:pl-72', 'lg:pl-20');
              el.sidebar.classList.remove('p-4'); el.sidebar.classList.add('p-2');
            } else {
              swapClass(el.sidebar, 'w-20', 'w-72');
              swapClass(el.content, 'lg:pl-20', 'lg:pl-72');
              el.sidebar.classList.remove('p-2'); el.sidebar.classList.add('p-4');
            }

            el.sidebar.querySelectorAll('.collapse-hide')
              .forEach(n => n.classList.toggle('hidden', collapsed));

            el.sidebar.querySelectorAll('nav a, #sidebar > a').forEach(a => {
              if (collapsed) { a.classList.add('justify-center','px-3'); a.classList.remove('px-4'); }
              else           { a.classList.remove('justify-center','px-3'); a.classList.add('px-4'); }
            });
            el.sidebar.querySelectorAll('.nav-label')
              .forEach(lbl => lbl.classList.toggle('hidden', collapsed));

            if (el.header && el.collapseBtn) {
              if (collapsed) {
                el.header.classList.remove('justify-between','justify-start');
                el.header.classList.add('justify-center');
                el.collapseBtn.classList.remove('inline-flex','rounded-lg','p-2','hover:bg-gray-100');
                el.collapseBtn.classList.add(
                  'w-12','h-12','flex','items-center','justify-center','mx-auto',
                  'rounded-2xl','text-slate-600','hover:bg-slate-50'
                );
              } else {
                el.header.classList.remove('justify-center');
                el.header.classList.add('justify-between');
                el.collapseBtn.classList.remove(
                  'w-12','h-12','flex','items-center','justify-center','mx-auto',
                  'rounded-2xl','text-slate-600','hover:bg-slate-50'
                );
                el.collapseBtn.classList.add('inline-flex','rounded-lg','p-2','hover:bg-gray-100');
              }
            }

            if (el.icCollapse && el.icExpand) {
              if (collapsed) { el.icCollapse.classList.add('hidden'); el.icExpand.classList.remove('hidden'); }
              else           { el.icCollapse.classList.remove('hidden'); el.icExpand.classList.add('hidden'); }
            }
          }

          function toggleSidebarCollapse(force) {
            const cur  = localStorage.getItem(LS_KEY) === '1';
            const next = (typeof force === 'boolean') ? force : !cur;
            localStorage.setItem(LS_KEY, next ? '1' : '0');
            applyCollapsedUI(next);
          }
          window.toggleSidebarCollapse = toggleSidebarCollapse;

          // Mobile slide in/out (opsional tapi rapi)
          function setAria(isOpen) {
            el.sidebar?.setAttribute('aria-hidden', String(!isOpen));
            el.openBtn?.setAttribute('aria-expanded', String(isOpen));
          }
          function lockScroll(lock) {
            document.documentElement.style.overflow = lock ? 'hidden' : '';
            document.body.style.overflow = lock ? 'hidden' : '';
          }
          function toggleSidebarMobile(open) {
            const shouldOpen = (typeof open === 'boolean') ? open : el.sidebar.classList.contains('-translate-x-full');
            if (shouldOpen) {
              el.sidebar.classList.remove('-translate-x-full');
              if (!isDesktop() && el.backdrop) {
                el.backdrop.classList.remove('pointer-events-none');
                el.backdrop.style.opacity = '1';
                lockScroll(true);
              }
              setAria(true);
            } else {
              el.sidebar.classList.add('-translate-x-full');
              if (!isDesktop() && el.backdrop) {
                el.backdrop.style.opacity = '0';
                setTimeout(() => el.backdrop.classList.add('pointer-events-none'), 200);
                lockScroll(false);
              }
              setAria(false);
            }
          }

          el.openBtn?.addEventListener('click', () => toggleSidebarMobile(true));
          el.closeBtn?.addEventListener('click', () => toggleSidebarMobile(false));
          el.backdrop?.addEventListener('click', () => toggleSidebarMobile(false));
          document.addEventListener('keydown', e => {
            if (e.key === 'Escape' && !isDesktop()) toggleSidebarMobile(false);
          });

          // kelas awal
          if (!el.sidebar.classList.contains('w-72') && !el.sidebar.classList.contains('w-20')) {
            el.sidebar.classList.add('w-72');
          }
          if (!el.content.classList.contains('lg:pl-72') && !el.content.classList.contains('lg:pl-20')) {
            el.content.classList.add('lg:pl-72');
          }

          // init dari localStorage
          const collapsed = localStorage.getItem(LS_KEY) === '1';
          applyCollapsedUI(collapsed);

          // responsif: reset state mobile/desktop
          window.addEventListener('resize', () => {
            if (isDesktop()) {
              el.sidebar.classList.remove('-translate-x-full');
              if (el.backdrop) {
                el.backdrop.style.opacity = '0';
                el.backdrop.classList.add('pointer-events-none');
              }
              lockScroll(false);
              setAria(true);
              // terapkan collapsed state tersimpan
              const col = localStorage.getItem(LS_KEY) === '1';
              applyCollapsedUI(col);
            } else {
              // mobile: biarkan tertutup default
              el.sidebar.classList.add('-translate-x-full');
              setAria(false);
            }
          });

          // klik tombol collapse header
          el.collapseBtn?.addEventListener('click', () => toggleSidebarCollapse());
        });
    </script>
    <!-- Validation setelah jQuery -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js" defer></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js" defer></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
