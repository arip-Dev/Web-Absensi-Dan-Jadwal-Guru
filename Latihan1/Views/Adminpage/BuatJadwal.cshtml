@{
    ViewData["Title"] = "Buat Jadwal";
    Layout = "_Layout";
}

<section class="mx-auto max-w-7xl px-4 py-8">
    <div class="mb-6">
        <p class="text-sm text-slate-500">Dashboard Admin</p>
        <h1 class="mt-1 text-3xl font-bold tracking-tight text-slate-900">Buat Jadwal</h1>
        <p class="mt-1 text-slate-500">Buat dan kelola jadwal mengajar guru</p>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold">Form Jadwal Baru</h2>
        <p class="mt-1 text-slate-500">Isi dari database • Cegah jadwal bentrok</p>

        <form id="formJadwal" class="mt-6 grid gap-5 md:grid-cols-2">
            <!-- Mata Pelajaran -->
            <div class="md:col-span-2">
                <label class="mb-2 block text-sm font-medium text-slate-700">Mata Pelajaran</label>
                <select id="mapel" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 focus:border-blue-500 focus:outline-none">
                    <option value="" selected>Pilih mata pelajaran</option>
                </select>
            </div>

            <!-- NAMA GURU (Combobox + search) -->
            <div class="md:col-span-2">
                <label class="mb-2 block text-sm font-medium text-slate-700">Nama Guru</label>

                <div id="guruCombo" class="relative">
                    <button id="guruInput" type="button"
                            class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-left focus:border-blue-500 focus:outline-none flex items-center justify-between gap-3">
                        <span id="guruInputText" class="truncate text-slate-700">Pilih guru (pilih mapel dulu)</span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 opacity-60" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M7 10l5 5 5-5z" />
                        </svg>
                    </button>

                    <div id="guruPanel"
                         class="absolute z-20 mt-2 hidden w-full overflow-hidden rounded-xl border border-slate-200 bg-white shadow-lg">
                        <div class="p-2 border-b border-slate-200">
                            <input id="guruSearch" type="text" placeholder="Cari nama guru..."
                                   class="w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none" />
                        </div>
                        <ul id="guruList" class="max-h-64 overflow-y-auto py-1 text-sm"></ul>
                    </div>
                </div>

                <!-- simpan id guru terpilih -->
                <input type="hidden" id="guru" value="">
                <p class="mt-1 text-xs text-slate-500">Klik field di atas untuk membuka daftar guru, lalu ketik untuk mencari.</p>
            </div>

            <!-- Info Guru -->
            <div class="md:col-span-2">
                <div id="guruInfo" class="hidden rounded-xl border border-slate-200 bg-slate-50 p-4">
                    <div class="flex flex-wrap items-center gap-3">
                        <span class="text-sm text-slate-600">Guru terpilih:</span>
                        <span id="giNama" class="font-semibold text-slate-900">-</span>
                        <span class="text-sm text-slate-500">•</span>
                        <span class="text-sm">Mapel: <b id="giMapel">-</b></span>
                        <span class="text-sm text-slate-500">•</span>
                        <span class="text-sm">Beban minggu ini: <b id="giLoad">0</b> / <b id="giMax">0</b> jam</span>
                        <span id="giBadge" class="rounded-full px-2 py-0.5 text-xs"></span>
                    </div>
                </div>
            </div>

            <!-- Kelas -->
            <div>
                <label class="mb-2 block text-sm font-medium text-slate-700">Kelas</label>
                <select id="kelas" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 focus:border-blue-500 focus:outline-none">
                    <option value="" selected>Pilih kelas</option>
                </select>
            </div>

            <!-- Hari -->
            <div>
                <label class="mb-2 block text-sm font-medium text-slate-700">Hari</label>
                <select id="hari" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 focus:border-blue-500 focus:outline-none">
                    <option value="" selected>Pilih hari</option>
                    <option value="1">Senin</option>
                    <option value="2">Selasa</option>
                    <option value="3">Rabu</option>
                    <option value="4">Kamis</option>
                    <option value="5">Jumat</option>
                    <option value="6">Sabtu</option>
                </select>
            </div>

            <!-- Ruangan (opsional — backend saat ini belum menyimpan) -->
            <div>
                <label class="mb-2 block text-sm font-medium text-slate-700">Kelas / Ruangan</label>
                <input id="ruangan" type="text" placeholder="Contoh: Kelas 10A / Lab Kimia"
                       class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 focus:border-blue-500 focus:outline-none" />
            </div>

            <!-- Slot Jam Pelajaran -->
            <div class="md:col-span-2">
                <label class="mb-2 block text-sm font-medium text-slate-700">Jam Pelajaran</label>
                <p class="text-xs text-slate-500 mb-2">
                    Pilih satu atau beberapa slot (harus berurutan). Sistem otomatis menyatukan menjadi waktu mulai & selesai.
                </p>

                <div id="slotWrap" class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3"></div>

                <!-- hidden agar kompatibel dgn API -->
                <input type="hidden" id="mulai" />
                <input type="hidden" id="selesai" />
            </div>

            <!-- Tombol -->
            <div class="md:col-span-2 flex items-center gap-3">
                <button id="btnSubmit" type="submit"
                        class="inline-flex items-center gap-2 rounded-xl bg-blue-600 px-5 py-3 font-medium text-white shadow hover:bg-blue-700 disabled:opacity-60 disabled:cursor-not-allowed">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M5 20h14v-2H5v2zm7-18L5.33 9h3.84v6h5.66V9h3.84L12 2z" /></svg>
                    Simpan Jadwal
                </button>
                <button type="button" id="btnReset"
                        class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-5 py-3 font-medium text-slate-700 hover:bg-slate-50">
                    Reset Form
                </button>
                <span id="msg" class="text-sm"></span>
            </div>
        </form>
    </div>

    <!-- DAFTAR -->
    <div class="mt-8 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="mb-5">
            <h2 class="text-2xl font-semibold">Daftar Jadwal</h2>
            <p class="mt-1 text-slate-500">Real-time dari DB</p>
        </div>

        <div class="mb-4 flex w-full rounded-2xl bg-slate-50 p-1">
            <button id="tabTable"
                    class="flex-1 rounded-xl px-4 py-2 text-sm font-medium text-slate-700 bg-white shadow-sm">
                ≣ Tabel
            </button>
            <button id="tabCalendar"
                    class="flex-1 rounded-xl px-4 py-2 text-sm font-medium text-slate-500 hover:text-slate-700">
                🗓 Kalender
            </button>
        </div>

        <div id="viewTable">
            <div class="overflow-x-auto">
                <table id="tblJadwal" class="min-w-full overflow-hidden rounded-2xl">
                    <thead class="bg-slate-50 text-slate-600">
                        <tr>
                            <th class="px-6 py-3 text-left text-sm font-semibold">Guru</th>
                            <th class="px-6 py-3 text-left text-sm font-semibold">Mata Pelajaran</th>
                            <th class="px-6 py-3 text-left text-sm font-semibold">Hari</th>
                            <th class="px-6 py-3 text-left text-sm font-semibold">Waktu</th>
                            <th class="px-6 py-3 text-left text-sm font-semibold">Kelas/Ruangan</th>
                            <th class="px-6 py-3 text-left text-sm font-semibold">Aksi</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200 text-slate-800"></tbody>
                </table>
            </div>
        </div>

        <div id="viewCalendar" class="hidden">
            <div class="relative">
                <button id="btnPrev"
                        class="absolute left-0 top-1/2 -translate-y-1/2 z-10 rounded-full bg-white shadow p-2 border border-slate-200 hover:bg-slate-50">
                    ‹
                </button>
                <button id="btnNext"
                        class="absolute right-0 top-1/2 -translate-y-1/2 z-10 rounded-full bg-white shadow p-2 border border-slate-200 hover:bg-slate-50">
                    ›
                </button>

                <div id="daysScroller" class="no-scrollbar overflow-x-auto scroll-smooth px-10">
                    <div id="daysWrap" class="flex gap-4 py-2"></div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }

        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>

    @section Scripts {
        <script>
            // ===== API endpoints (disesuaikan dgn controller) =====
            const api = {
              mapel: '/api/schedule/mapel',
              kelas: '/api/schedule/kelas',
              guruByMapel: (m) => `/api/schedule/guru?mapel=${encodeURIComponent(m)}`,
              list: '/api/schedule',
              create: '/api/schedule',
              update: (id) => `/api/schedule/${id}`,
              delete: (id) => `/api/schedule/${id}`
            };

            // ===== Elemen =====
            const el = {
              mapel: document.getElementById('mapel'),
              guruHidden: document.getElementById('guru'),
              kelas: document.getElementById('kelas'),
              hari: document.getElementById('hari'),
              ruangan: document.getElementById('ruangan'),
              mulai: document.getElementById('mulai'),
              selesai: document.getElementById('selesai'),
              form: document.getElementById('formJadwal'),
              btnSubmit: document.getElementById('btnSubmit'),
              btnReset: document.getElementById('btnReset'),
              msg: document.getElementById('msg'),

              // combobox guru
              guruInput: document.getElementById('guruInput'),
              guruInputText: document.getElementById('guruInputText'),
              guruPanel: document.getElementById('guruPanel'),
              guruSearch: document.getElementById('guruSearch'),
              guruList: document.getElementById('guruList'),

              // info guru
              giWrap: document.getElementById('guruInfo'),
              giNama: document.getElementById('giNama'),
              giMapel: document.getElementById('giMapel'),
              giLoad: document.getElementById('giLoad'),
              giMax: document.getElementById('giMax'),
              giBadge: document.getElementById('giBadge'),

              // slot
              slotWrap: document.getElementById('slotWrap'),

              // list & kalender
              tblBody: document.querySelector('#tblJadwal tbody'),
              tabTable: document.getElementById('tabTable'),
              tabCalendar: document.getElementById('tabCalendar'),
              viewTable: document.getElementById('viewTable'),
              viewCalendar: document.getElementById('viewCalendar'),
              daysWrap: document.getElementById('daysWrap'),
              scroller: document.getElementById('daysScroller'),
              btnPrev: document.getElementById('btnPrev'),
              btnNext: document.getElementById('btnNext'),
            };

            function setMsg(text, ok=true){
              el.msg.textContent = text || '';
              el.msg.className = 'text-sm ' + (ok ? 'text-emerald-600' : 'text-rose-600');
            }

            // dukung angka 1..7 atau string "Senin"
            function dayLabel(h){
              if (typeof h === 'number') {
                return {1:'Senin',2:'Selasa',3:'Rabu',4:'Kamis',5:'Jumat',6:'Sabtu',7:'Minggu'}[h] || '-';
              }
              if (!h) return '-';
              const map = {senin:'Senin', selasa:'Selasa', rabu:'Rabu', kamis:'Kamis', jumat:'Jumat', sabtu:'Sabtu', minggu:'Minggu'};
              const k = String(h).toLowerCase();
              return map[k] || h; // fallback tampilkan apa adanya
            }

            // ====== Definisi slot jam pelajaran ======
            const SLOT_DEFS = [
              ["07:00","08:00"],
              ["08:00","09:00"],
              ["09:00","10:00"],
              ["10:00","11:00"],
              ["11:00","12:00"],
              ["12:00","13:00"],
              ["13:00","14:00"],
              ["14:00","15:00"],
              ["15:00","16:00"],
            ];

            // ====== STATE ======
            let guruRaw = []; // [{ id, nama, mapel, maxWeeklyLoad, currentLoadMinutes/currentLoadHours }, ...]
            let editingId = null;      // << jadwal yang sedang diedit (kalau ada)
            const originalBtnText = "Simpan Jadwal";

            // ====== INIT ======
            (async function init(){
              // mapel
              const m = await fetch(api.mapel).then(r=>r.json());
              el.mapel.innerHTML = `<option value="">Pilih mata pelajaran</option>` + m.map(x=>`<option>${x}</option>`).join('');

              // kelas
              const k = await fetch(api.kelas).then(r=>r.json());
              el.kelas.innerHTML = `<option value="">Pilih kelas</option>` + k.map(x=>`<option value="${x.id}">${x.tingkat}-${x.namaSingkat}</option>`).join('');

              // build slot grid
              buildSlotGrid();

              await reloadJadwal();

              // events
              el.mapel.addEventListener('change', onMapelChange);

              // combobox guru
              el.guruInput.addEventListener('click', () => {
                if (!el.mapel.value.trim()) { setMsg('Pilih mata pelajaran terlebih dahulu.', false); return; }
                openGuruPanel();
              });
              el.guruSearch.addEventListener('input', () => {
                const q = (el.guruSearch.value||'').toLowerCase().trim();
                const filtered = guruRaw.filter(g => (g.nama||'').toLowerCase().includes(q));
                renderGuruList(filtered);
              });

              el.btnReset.addEventListener('click', () => {
              el.form.reset();
              resetGuruInfo();
              clearSlots();
              editingId = null;                     // keluar dari mode edit
              el.btnSubmit.textContent = originalBtnText;   // kembalikan label tombol
              el.btnSubmit.disabled = false;
              setMsg('');
            });


              el.form.addEventListener('submit', onSubmit);
              el.tabTable.addEventListener('click', ()=>setActiveTab('table'));
              el.tabCalendar.addEventListener('click', ()=>setActiveTab('calendar'));
              el.btnPrev.addEventListener('click', ()=>scrollCols(-1));
              el.btnNext.addEventListener('click', ()=>scrollCols(1));
              setActiveTab('table');
            })();

            // ====== Slot UI ======
            function buildSlotGrid(){
              el.slotWrap.innerHTML = SLOT_DEFS.map((pair, idx) => {
                const [s, e] = pair;
                const label = `${s.substring(0,5)} - ${e.substring(0,5)}`;
                return `
                  <label class="flex items-center gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 hover:bg-slate-50 cursor-pointer">
                    <input type="checkbox" class="slotItem h-4 w-4" value="${s}|${e}" data-index="${idx}"/>
                    <span class="text-sm text-slate-800">${label}</span>
                  </label>
                `;
              }).join('');
            }

            function clearSlots(){
              document.querySelectorAll('.slotItem').forEach(cb => cb.checked = false);
              el.mulai.value = '';
              el.selesai.value = '';
            }

            function getSelectedSlots(){
              const boxes = Array.from(document.querySelectorAll('.slotItem')).filter(cb => cb.checked);
              const sorted = boxes.sort((a,b) => parseInt(a.dataset.index)-parseInt(b.dataset.index));
              return sorted.map(cb => {
                const [start, end] = cb.value.split('|');
                return { start, end, idx: parseInt(cb.dataset.index) };
              });
            }

            function areSlotsContiguous(sel){
              if (sel.length <= 1) return true;
              for (let i=1; i<sel.length; i++){
                if (sel[i].idx !== sel[i-1].idx + 1) return false;
              }
              return true;
            }

            // ====== Combobox Guru ======
            let outsideHandler = null;
            function openGuruPanel() {
              if (el.guruPanel.classList.contains('hidden')) {
                el.guruPanel.classList.remove('hidden');
                el.guruSearch.value = '';
                renderGuruList(guruRaw);
                setTimeout(()=> el.guruSearch.focus(), 0);

                outsideHandler = (e) => {
                  if (!el.guruPanel.contains(e.target) && !el.guruInput.contains(e.target)) closeGuruPanel();
                };
                document.addEventListener('mousedown', outsideHandler);
                document.addEventListener('keydown', escToClose);
              }
            }
            function closeGuruPanel() {
              if (!el.guruPanel.classList.contains('hidden')) {
                el.guruPanel.classList.add('hidden');
                if (outsideHandler) {
                  document.removeEventListener('mousedown', outsideHandler);
                  document.removeEventListener('keydown', escToClose);
                  outsideHandler = null;
                }
              }
            }
            function escToClose(e){ if(e.key==='Escape') closeGuruPanel(); }

            function renderGuruList(list){
              if (!Array.isArray(list) || list.length===0){
                el.guruList.innerHTML = `<li class="px-3 py-2 text-slate-400">Tidak ada guru</li>`;
                return;
              }
              el.guruList.innerHTML = list.map(g=>{
                const minutes = (g.currentLoadMinutes ?? 0);
                const hoursFromMinutes = Math.round((minutes/60)*10)/10;
                const hours = (g.currentLoadHours ?? hoursFromMinutes);
                const max = g.maxWeeklyLoad ?? 0;
                const ratio = (max>0) ? (hours/max) : 0;
                const badgeClass = ratio>=1 ? 'bg-rose-100 text-rose-700' : ratio>=0.75 ? 'bg-amber-100 text-amber-700' : 'bg-emerald-100 text-emerald-700';
                const badgeText  = ratio>=1 ? 'Penuh' : ratio>=0.75 ? 'Hampir penuh' : 'Tersedia';

                return `
                  <li class="flex items-center justify-between gap-3 px-3 py-2 hover:bg-slate-50 cursor-pointer"
                      data-id="${g.id}" data-nama="${g.nama}" data-mapel="${g.mapel}"
                      data-load="${hours}" data-max="${max}">
                    <div class="min-w-0">
                      <div class="font-medium text-slate-900 truncate">${g.nama}</div>
                      <div class="text-xs text-slate-500">Mapel: ${g.mapel} • Beban: ${hours} / ${max} jam</div>
                    </div>
                    <div class="text-[10px] rounded-full px-2 py-0.5 ${badgeClass}">${badgeText}</div>
                  </li>`;
              }).join('');

              Array.from(el.guruList.querySelectorAll('li[data-id]')).forEach(li=>{
                li.addEventListener('click', ()=> selectGuruFromLi(li));
              });
            }

            function selectGuruFromLi(li){
              const id   = parseInt(li.dataset.id||'0',10);
              const nama = li.dataset.nama || '';
              const mapel= li.dataset.mapel || '';
              const load = parseFloat(li.dataset.load||'0');
              const max  = parseFloat(li.dataset.max||'0');

              el.guruHidden.value = String(id);
              el.guruInputText.textContent = nama || 'Pilih guru';
              closeGuruPanel();

              el.giWrap.classList.remove('hidden');
              el.giNama.textContent = nama || '-';
              el.giMapel.textContent = mapel || '-';
              el.giLoad.textContent = isFinite(load)? load : 0;
              el.giMax.textContent  = isFinite(max)?  max  : 0;

              const ratio = (isFinite(load)&&isFinite(max)&&max>0) ? (load/max) : 0;
              el.giBadge.className = 'rounded-full px-2 py-0.5 text-xs ' + (ratio>=1 ? 'bg-rose-100 text-rose-700' : ratio>=0.75 ? 'bg-amber-100 text-amber-700' : 'bg-emerald-100 text-emerald-700');
              el.giBadge.textContent = ratio>=1 ? 'Penuh' : ratio>=0.75 ? 'Hampir penuh' : 'Tersedia';
            }

            function resetGuruInfo(){
              el.guruHidden.value = '';
              el.guruInputText.textContent = 'Pilih guru (pilih mapel dulu)';
              el.giWrap.classList.add('hidden');
              el.giNama.textContent='-';
              el.giMapel.textContent='-';
              el.giLoad.textContent='0';
              el.giMax.textContent='0';
              el.giBadge.className='hidden';
              el.giBadge.textContent='';
            }

            // ====== MAPEL CHANGE → LOAD GURU ======
            async function onMapelChange() {
              // setiap ganti mapel: reset guru terpilih, tutup panel, kosongkan slot
              resetGuruInfo();
              clearSlots();
              closeGuruPanel();
              setMsg('');

              const m = el.mapel.value.trim();
              if (!m) {
                guruRaw = [];
                return;
              }

              try {
                guruRaw = await fetch(api.guruByMapel(m)).then(r => r.json());
              } catch {
                guruRaw = [];
                setMsg('Gagal memuat daftar guru.', false);
              }
            }


                        // ====== SUBMIT ======
            async function onSubmit(e){
              e.preventDefault();
              setMsg('');

              const mapel  = el.mapel.value.trim();
              const guruId = parseInt(el.guruHidden.value||'0',10);
              const kelasId= parseInt(el.kelas.value||'0',10);
              const hari   = parseInt(el.hari.value||'0',10);
              const ruangan= el.ruangan.value.trim();

              // Ambil dari slot
              const selSlots = getSelectedSlots();
              if(selSlots.length === 0){
                setMsg('Pilih minimal satu slot jam pelajaran.', false); return;
              }
              if(!areSlotsContiguous(selSlots)){
                setMsg('Slot yang dipilih harus berurutan (kontigu).', false); return;
              }
              const mulai   = selSlots[0].start;
              const selesai = selSlots[selSlots.length-1].end;
              el.mulai.value   = mulai;
              el.selesai.value = selesai;

              if(!mapel || !guruId || !kelasId || !hari){
                setMsg('Lengkapi semua isian wajib.', false); return;
              }
              if(selesai <= mulai){
                setMsg('Waktu selesai harus > waktu mulai.', false); return;
              }

              el.btnSubmit.disabled = true;

              const payload = {
                GuruId: guruId,
                Mapel: mapel,
                Hari: hari,
                Mulai: mulai,
                Selesai: selesai,
                KelasId: kelasId,
                Ruangan: ruangan
              };

              let res;
              if (editingId !== null) {
                // MODE EDIT → PUT
                res = await fetch(api.update(editingId), {
                  method: 'PUT',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify(payload)
                });
              } else {
                // MODE TAMBAH → POST
                res = await fetch(api.create, {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify(payload)
                });
              }

              if(res.status === 409){
                const j = await res.text().catch(()=> 'Bentrok jadwal.');
                setMsg(j || 'Bentrok jadwal.', false);
                el.btnSubmit.disabled = false;
                return;
              }
              if(!res.ok){
                const j = await res.text().catch(()=> 'Gagal simpan.');
                setMsg(j || 'Gagal simpan.', false);
                el.btnSubmit.disabled = false;
                return;
              }

              setMsg(editingId !== null ? 'Perubahan jadwal disimpan.' : 'Jadwal tersimpan.', true);

              // reset ke mode tambah lagi
              el.form.reset();
              resetGuruInfo();
              clearSlots();
              editingId = null;
              el.btnSubmit.textContent = originalBtnText;
              el.btnSubmit.disabled = false;

              await reloadJadwal();
            }

            // ====== LIST ======
            async function reloadJadwal(){
              const rows = await fetch(api.list).then(r=>r.json()).catch(()=>[]);
              console.log('API /api/schedule →', rows);
              el.tblBody.innerHTML = rows.map(r => {
              const id   = r.id;
              const guruId  = r.guruId;
              const guru = r.guru ?? r.guruNama ?? '-';
              const mapel = r.mapel ?? '-';
              const hari  = dayLabel(r.hari);
              const mulai = (r.mulai ?? '').toString().substring(0,5);
              const selesai = (r.selesai ?? '').toString().substring(0,5);
              const kelasId = r.kelasId;
              const kelas = r.kelas ?? r.kelasNama ?? '-';
              const ruangan = r.ruangan ?? '';

              return `
                <tr>
                  <td class="px-6 py-4">${guru}</td>
                  <td class="px-6 py-4">
                    <span class="rounded-full bg-slate-100 px-3 py-1 text-sm">${mapel}</span>
                  </td>
                  <td class="px-6 py-4">${hari}</td>
                  <td class="px-6 py-4">${mulai} - ${selesai}</td>
                  <td class="px-6 py-4">${kelas}${ruangan ? ' / ' + ruangan : ''}</td>
                  <td class="px-6 py-4 text-sm">
                    <button type="button"
                            class="text-blue-600 hover:underline mr-3 btn-edit"
                            data-id="${id}"
                            data-guru-id="${guruId}"
                            data-mapel="${mapel}"
                            data-hari="${r.hari}"
                            data-kelas-id="${kelasId}"
                            data-mulai="${mulai}"
                            data-selesai="${selesai}"
                            data-ruangan="${ruangan}">
                      Edit
                    </button>
                    <button type="button"
                            class="text-rose-600 hover:underline btn-del"
                            data-id="${id}">
                      Hapus
                    </button>
                  </td>
                </tr>`;
            }).join('');
            // pasang handler tombol edit & hapus
            el.tblBody.querySelectorAll('.btn-del').forEach(btn => {
              btn.addEventListener('click', onDeleteClick);
            });
            el.tblBody.querySelectorAll('.btn-edit').forEach(btn => {
              btn.addEventListener('click', onEditClick);
            });

            //function delete jadwal
              async function onDeleteClick(e) {
              const id = parseInt(e.currentTarget.dataset.id || '0', 10);
              if (!id) return;
              if (!confirm('Hapus jadwal ini?')) return;

              const res = await fetch(api.delete(id), { method: 'DELETE' });
              if (!res.ok && res.status !== 404) {
                setMsg('Gagal menghapus jadwal.', false);
                return;
              }
              setMsg('Jadwal dihapus.', true);
              await reloadJadwal();
            }
            // function edit jadwal
              async function onEditClick(e) {
              const btn = e.currentTarget;
              const id = parseInt(btn.dataset.id || '0', 10);
              if (!id) return;

              editingId = id;
              el.btnSubmit.textContent = 'Update Jadwal';

              // isi form dari data dataset
              const mapel  = btn.dataset.mapel || '';
              const guruId = parseInt(btn.dataset.guruId || '0', 10);
              const hari   = btn.dataset.hari || '';
              const kelasId= btn.dataset.kelasId || '';
              const mulai  = btn.dataset.mulai || '';
              const selesai= btn.dataset.selesai || '';
              const ruangan= btn.dataset.ruangan || '';

              // set dropdown
              el.mapel.value = mapel;
              await onMapelChange();   // load guruRaw sesuai mapel

              // pilih guru di combobox
              const g = guruRaw.find(x => x.id === guruId);
              if (g) {
                el.guruHidden.value = String(guruId);
                el.guruInputText.textContent = g.nama;
                el.giWrap.classList.remove('hidden');
                el.giNama.textContent = g.nama;
                el.giMapel.textContent = mapel;
                el.giLoad.textContent = g.currentLoadHours ?? 0;
                el.giMax.textContent  = g.maxWeeklyLoad ?? 0;
              } else {
                resetGuruInfo();
              }

              el.kelas.value = kelasId;
              el.hari.value  = String(hari);
              el.ruangan.value = ruangan;

              // set slot jam dari mulai–selesai
              clearSlots();
              const startIdx = SLOT_DEFS.findIndex(p => p[0] === mulai);
              const endIdx   = SLOT_DEFS.findIndex(p => p[1] === selesai);
              const boxes = Array.from(document.querySelectorAll('.slotItem'));
              boxes.forEach(cb => {
                const idx = parseInt(cb.dataset.index, 10);
                if (idx >= startIdx && idx <= endIdx) cb.checked = true;
              });
              el.mulai.value = mulai;
              el.selesai.value = selesai;
              el.form.scrollIntoView({ behavior: 'smooth', block: 'start' });
              setMsg('Mode edit jadwal. Ubah data lalu klik "Update Jadwal".', true);
            }

              // data utk kalender
              window.scheduleData = rows.map(r=>{
                const guru  = r.guru ?? r.guruNama ?? '-';
                const mapel = r.mapel ?? '-';
                const hari  = dayLabel(r.hari);
                const mulai = (r.mulai ?? '').toString().substring(0,5);
                const selesai = (r.selesai ?? '').toString().substring(0,5);
                const kelas = r.kelas ?? r.kelasNama ?? '-';
                const ruangan = r.ruangan ?? '';
                return { guru, mapel, hari, mulai, selesai, ruangan: kelas + (ruangan? ' / '+ruangan:'') };
              });

              if(!el.viewCalendar.classList.contains('hidden')) renderCalendar();
            }

            // ====== Tabs & Kalender ======
            function setActiveTab(tab){
              const active = "flex-1 rounded-xl px-4 py-2 text-sm font-medium text-slate-700 bg-white shadow-sm";
              const inactive = "flex-1 rounded-xl px-4 py-2 text-sm font-medium text-slate-500 hover:text-slate-700";
              if(tab==='table'){
                el.tabTable.className=active; el.tabCalendar.className=inactive;
                el.viewTable.classList.remove('hidden'); el.viewCalendar.classList.add('hidden');
              } else {
                el.tabTable.className=inactive; el.tabCalendar.className=active;
                el.viewTable.classList.add('hidden'); el.viewCalendar.classList.remove('hidden');
                renderCalendar();
              }
            }

            function renderCalendar(){
              const days = ["Senin","Selasa","Rabu","Kamis","Jumat","Sabtu"];
              el.daysWrap.innerHTML = "";
              days.forEach(d=>{
                const col = document.createElement('div');
                col.className = "shrink-0 w-[85%] sm:w-[60%] md:w-[45%] lg:w-[32%] xl:w-[28%] rounded-2xl border border-slate-200 p-4";
                const h = document.createElement('h3');
                h.className = "mb-3 text-lg font-semibold text-slate-900";
                h.textContent = d; col.appendChild(h);

                const events = (window.scheduleData||[]).filter(x=>x.hari===d);
                if(events.length===0){
                  const empty = document.createElement('div');
                  empty.className="text-slate-400 text-sm"; empty.textContent="Belum ada jadwal";
                  col.appendChild(empty);
                } else {
                  events.forEach(ev=>{
                    const card = document.createElement('div');
                    card.className="mb-3 rounded-2xl bg-blue-50 px-4 py-3 text-blue-900 ring-1 ring-blue-100";
                    card.innerHTML = `
                      <div class="text-sm font-semibold">${ev.mulai} - ${ev.selesai}</div>
                      <div class="mt-1 font-semibold">${ev.mapel}</div>
                      <div class="text-sm text-blue-700">${ev.guru}</div>
                      <div class="text-sm text-blue-700">${ev.ruangan}</div>`;
                    col.appendChild(card);
                  });
                }
                el.daysWrap.appendChild(col);
              });
            }

            function scrollCols(dir=1){
              const first = el.daysWrap.firstElementChild; if(!first) return;
              const gap = 16, step = first.getBoundingClientRect().width + gap;
              el.scroller.scrollBy({ left: dir*step, behavior: 'smooth' });
            }
        </script>
    }
</section>
