@model Latihan1.Models.TeacherListViewModel
@{
    ViewData["Title"] = "Data Guru";
    var startNo = 1 + ((Model.Page - 1) * Model.PageSize);

    // 1. Ambil Pesan Error Spesifik (Jadwal)
    var errGuruSchedule = TempData["ErrGuruSchedule"] as string;
    
    // 2. Ambil Pesan Error Umum (Database/FK Constraint) - INI YANG BARU
    var errGeneral = TempData["Err"] as string;

    // 3. Ambil Pesan Sukses
    var successMsg = TempData["ok"] as string;
}

@* --- MODAL 2: ERROR UMUM / DATABASE (BARU) --- *@
@if (!string.IsNullOrEmpty(errGeneral))
{
    <div id="generalErrorModal" class="fixed inset-0 z-[60] flex items-center justify-center bg-black/50 backdrop-blur-sm px-4">
        <div class="w-full max-w-md rounded-2xl bg-white shadow-2xl p-6 transform scale-100 transition-all">
            <div class="flex items-start gap-4 mb-4">
                <div class="flex-shrink-0 bg-red-100 rounded-full p-2">
                    <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-gray-900">Gagal Menghapus</h3>
                    <p class="mt-2 text-sm text-gray-600 leading-relaxed">
                        @errGeneral
                    </p>
                </div>
            </div>
            <div class="flex justify-end bg-gray-50 -mx-6 -mb-6 px-6 py-4 rounded-b-2xl">
                <button type="button"
                        class="rounded-xl bg-red-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-red-700 shadow-sm shadow-red-200 transition-all focus:ring-4 focus:ring-red-100"
                        onclick="document.getElementById('generalErrorModal')?.remove();">
                    Saya Mengerti
                </button>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(errGuruSchedule))
{
    <div id="guruScheduleModal"
         class="fixed inset-0 z-50 flex items-center justify-center bg-black/40">
        <div class="w-full max-w-md rounded-2xl bg-white shadow-lg p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">
                Tidak dapat menghapus guru
            </h3>
            <p class="text-sm text-gray-700 mb-4">
                @errGuruSchedule
            </p>
            <div class="flex justify-end">
                <button type="button"
                        class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700"
                        onclick="document.getElementById('guruScheduleModal')?.remove();">
                    Tutup
                </button>
            </div>
        </div>
    </div>
}

<div class="bg-gray-50 text-gray-900">
    <main class="mx-auto max-w-screen-xl w-full px-4 py-6">
        @* --- ALERT SUKSES (Banner Hijau) --- *@
        @if (!string.IsNullOrEmpty(successMsg))
{
    <div class="mb-6 flex items-center p-4 text-green-800 rounded-xl bg-green-100 border-2 border-green-500 shadow-sm" role="alert">
        
        <svg class="flex-shrink-0 w-5 h-5 mr-3 text-green-700" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5Zm3.707 8.207-4 4a1 1 0 0 1-1.414 0l-2-2a1 1 0 0 1 1.414-1.414L9 10.586l3.293-3.293a1 1 0 0 1 1.414 1.414Z"/>
        </svg>
        
        <div class="text-sm font-bold">
            @successMsg
        </div>

        <button type="button" class="ml-auto -mx-1.5 -my-1.5 bg-green-100 text-green-500 rounded-lg focus:ring-2 focus:ring-green-400 p-1.5 hover:bg-green-200 inline-flex items-center justify-center h-8 w-8" aria-label="Close" onclick="this.parentElement.remove()">
            <span class="sr-only">Close</span>
            <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
            </svg>
        </button>
    </div>
}
        <div class="flex items-center justify-between mb-6">
            <div>
                <h2 class="text-2xl font-semibold">Data Guru</h2>
                <p class="text-gray-500 text-sm">Kelola informasi guru dan pengajar</p>
            </div>
            <a asp-controller="Dataguru" asp-action="Create"
               class="flex items-center gap-2 rounded-lg bg-blue-600 px-4 py-2 text-white hover:bg-blue-700">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Tambah Guru
            </a>
        </div>

        <!-- Toolbar -->
        <form method="get" asp-controller="Dataguru" asp-action="Teacher_data"
              class="mb-6 flex flex-wrap items-center gap-3">
            <div class="relative w-72 md:w-96">
                <input name="q" value="@(Model.Query ?? "")"
                       placeholder="Cari nama, NIP, atau mata pelajaran..."
                       class="w-full rounded-lg border border-gray-300 bg-white py-2 pl-10 pr-4 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-200" />
                <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-3 top-2.5 h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35m0 0A7.5 7.5 0 104.5 4.5a7.5 7.5 0 0012.15 12.15z" />
                </svg>
            </div>

            <div class="flex items-center gap-2">
                <label class="text-sm text-gray-600">Tampilkan</label>
                <select name="pageSize" class="rounded-lg border border-gray-300 bg-white py-2 px-3 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-200">
                    <option value="10" selected="@(Model.PageSize == 10)">10</option>
                    <option value="25" selected="@(Model.PageSize == 25)">25</option>
                    <option value="50" selected="@(Model.PageSize == 50)">50</option>
                    <option value="100" selected="@(Model.PageSize == 100)">100</option>
                </select>
                <input type="hidden" name="page" value="1" />
                <button type="submit" class="rounded-lg bg-gray-800 px-3 py-2 text-sm text-white hover:bg-gray-700">Apply</button>
            </div>
        </form>

        <!-- Table -->
        <div class="rounded-xl border border-gray-200 bg-white shadow-sm overflow-x-hidden">
            <table class="w-full table-fixed border-collapse text-xs lg:text-[13px] leading-snug">
                <!-- Fiks lebar kolom agar tidak melebar -->
                <colgroup>
                    <col style="width:48px" />
                    <col style="width:18%" />
                    <col style="width:8%" />
                    <col style="width:14%" />
                    <col style="width:24%" />
                    <col style="width:8%" />
                    <col style="width:8%" />
                    <col style="width:7%" />
                </colgroup>

                <thead class="bg-gray-100 text-left">
                    <tr>
                        <th class="px-3 py-2 font-medium text-gray-600 text-center">No.</th>
                        <th class="px-4 py-2 font-medium text-gray-600">Nama</th>
                        <th class="px-4 py-2 font-medium text-gray-600">QR Code</th>
                        <th class="px-4 py-2 font-medium text-gray-600">NIP</th>
                        <th class="px-4 py-2 font-medium text-gray-600">Mata Pelajaran</th>
                        <th class="px-4 py-2 font-medium text-gray-600">Email</th>
                        <th class="px-4 py-2 font-medium text-gray-600">Jam</th>
                        <th class="px-4 py-2 font-medium text-gray-600">Status</th>
                        <th class="px-4 py-2 font-medium text-gray-600">Aksi</th>
                    </tr>
                </thead>

                <tbody class="divide-y divide-gray-200">
                    @{
                        var no = startNo;
                    }
                    @foreach (var t in Model.Items)
                    {
                        <tr class="align-top">
                            <td class="px-3 py-2 text-center">@no</td>
                            <!-- wrap teks panjang agar tidak melebar -->
                            <td class="px-4 py-2 whitespace-normal break-words">@t.Nama</td>

                            <td class="px-4 py-2">
                                @if (!string.IsNullOrEmpty(t.QRCodeBase64))
                                {
                                    <div class="flex flex-col items-center gap-1">
                                        <img src="@t.QRCodeBase64"
                                             alt="QR @t.NIP"
                                             class="h-10 w-10 cursor-pointer rounded border border-gray-200 hover:opacity-80 hover:shadow-md transition-all"
                                             onclick="showQrModal('@t.QRCodeBase64', '@t.Nama', '@t.NIP')" />

                                        <span class="text-[10px] text-gray-400 cursor-pointer hover:text-blue-600"
                                              onclick="showQrModal('@t.QRCodeBase64', '@t.Nama', '@t.NIP')">
                                            Lihat
                                        </span>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-xs text-gray-400 italic">No QR</span>
                                }
                            </td>

                            <td class="px-4 py-2 whitespace-normal break-words">@t.NIP</td>

                            <!-- MATA PELAJARAN (BADGE) -->
                            <td class="px-4 py-2">
                                @{
                                    // pecah string "asd, bahasa china, ..." menjadi list
                                    var mapels = (t.MapelNama ?? "")
                                    .Split(',', StringSplitOptions.RemoveEmptyEntries)
                                    .Select(x => x.Trim())
                                    .ToList();

                                    var maxShow = 3; // berapa badge yang ditampilkan
                                }

                                @if (mapels.Count == 0)
                                {
                                    <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-[11px] text-gray-500">
                                        (Tanpa mapel)
                                    </span>
                                }
                                else
                                {
                                    <div class="flex flex-wrap gap-1" title="@t.MapelNama">
                                        @foreach (var m in mapels.Take(maxShow))
                                        {
                                            <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-[11px] text-gray-700">
                                                @m
                                            </span>
                                        }

                                        @if (mapels.Count > maxShow)
                                        {
                                            <span class="text-[11px] text-gray-500">
                                                +@((mapels.Count - maxShow)) lagi
                                            </span>
                                        }
                                    </div>
                                }
                            </td>

                            <td class="px-4 py-2 whitespace-normal break-words" title="@t.Email">@t.Email</td>
                            <td class="px-4 py-2">@t.JamMengajar jam</td>

                            <td class="px-4 py-2">
                                @if (t.IsActive)
                                {
                                    <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-[11px] font-medium text-blue-700">Aktif</span>
                                }
                                else
                                {
                                    <span class="rounded-full bg-gray-200 px-2.5 py-0.5 text-[11px] font-medium text-gray-700">Tidak Aktif</span>
                                }
                            </td>

                            <td class="px-4 py-2">
                                <div class="flex items-center gap-2">
                                    <a asp-controller="Dataguru" asp-action="Edit" asp-route-id="@t.Id"
                                       class="text-gray-600 hover:text-blue-600">Edit</a>
                                    <form asp-controller="Dataguru" asp-action="Delete" asp-route-id="@t.Id" method="post"
                                          onsubmit="return confirm('Hapus data guru ini?');">
                                        @Html.AntiForgeryToken()
                                        <button class="text-gray-600 hover:text-red-600">Hapus</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        no++;
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="mt-4 flex items-center justify-between text-sm text-gray-600">
            <div>
                Menampilkan <span class="font-medium">@Model.Items.Count()</span> dari
                <span class="font-medium">@Model.Total</span> data • Halaman
                <span class="font-medium">@Model.Page</span> / <span class="font-medium">@Model.TotalPages</span>
            </div>
            <div class="flex items-center gap-2">
                @{
                    string baseUrl = Url.Action("Teacher_data", "Dataguru")!;
                    string qsCommon = $"q={Uri.EscapeDataString(Model.Query ?? string.Empty)}&pageSize={Model.PageSize}";
                    int prevPage = Math.Max(1, Model.Page - 1);
                    int nextPage = Math.Min(Model.TotalPages, Model.Page + 1);
                }
                <a class="rounded-lg border px-3 py-1 hover:bg-gray-100 @(Model.Page == 1 ? "pointer-events-none opacity-50" : "")"
                   href="@($"{baseUrl}?{qsCommon}&page=1")">« Awal</a>
                <a class="rounded-lg border px-3 py-1 hover:bg-gray-100 @(Model.Page == 1 ? "pointer-events-none opacity-50" : "")"
                   href="@($"{baseUrl}?{qsCommon}&page={prevPage}")">‹ Prev</a>
                <a class="rounded-lg border px-3 py-1 hover:bg-gray-100 @(Model.Page == Model.TotalPages ? "pointer-events-none opacity-50" : "")"
                   href="@($"{baseUrl}?{qsCommon}&page={nextPage}")">Next ›</a>
                <a class="rounded-lg border px-3 py-1 hover:bg-gray-100 @(Model.Page == Model.TotalPages ? "pointer-events-none opacity-50" : "")"
                   href="@($"{baseUrl}?{qsCommon}&page={Model.TotalPages}")">Akhir »</a>
            </div>
        </div>
    </main>

    <div id="qrModal" tabindex="-1" aria-hidden="true"
         class="fixed inset-0 z-50 hidden flex items-center justify-center p-4 overflow-x-hidden overflow-y-auto bg-black/60 backdrop-blur-sm transition-opacity">

        <div class="relative w-full max-w-sm rounded-2xl bg-white shadow-2xl ring-1 ring-gray-200">

            <button type="button" onclick="closeQrModal()"
                    class="absolute right-4 top-4 rounded-lg bg-gray-100 p-2 text-gray-400 hover:bg-gray-200 hover:text-gray-900 focus:outline-none focus:ring-2 focus:ring-gray-300">
                <svg class="h-4 w-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6" />
                </svg>
                <span class="sr-only">Tutup modal</span>
            </button>

            <div class="p-6 text-center">
                <h3 class="mb-1 text-lg font-semibold text-gray-900" id="qrModalNama">Nama Guru</h3>
                <p class="mb-4 text-sm text-gray-500" id="qrModalNip">NIP: -</p>

                <div class="mx-auto mb-6 flex h-64 w-64 items-center justify-center rounded-xl bg-gray-50 border border-gray-200 p-2 shadow-inner">
                    <img id="qrModalImg" src="" alt="QR Code Besar" class="h-full w-full object-contain mix-blend-multiply" />
                </div>

                <div class="flex items-center justify-center gap-3">
                    <a id="btnDownloadQr" href="#" download="qrcode.png"
                       class="inline-flex items-center gap-2 rounded-lg bg-blue-600 px-5 py-2.5 text-center text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-4 focus:ring-blue-300">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                        </svg>
                        Unduh
                    </a>

                    <button onclick="closeQrModal()" type="button"
                            class="rounded-lg border border-gray-200 bg-white px-5 py-2.5 text-sm font-medium text-gray-500 hover:bg-gray-100 hover:text-gray-900 focus:z-10 focus:outline-none focus:ring-4 focus:ring-gray-200">
                        Tutup
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Elemen DOM
        const qrModal = document.getElementById('qrModal');
        const qrModalImg = document.getElementById('qrModalImg');
        const qrModalNama = document.getElementById('qrModalNama');
        const qrModalNip = document.getElementById('qrModalNip');
        const btnDownloadQr = document.getElementById('btnDownloadQr');

        // Fungsi Buka Modal
        function showQrModal(base64Img, nama, nip) {
            // Set data ke elemen modal
            qrModalImg.src = base64Img;
            qrModalNama.innerText = nama;
            qrModalNip.innerText = nip ? "NIP: " + nip : "NIP: -";

            // Setup tombol download
            btnDownloadQr.href = base64Img;
            btnDownloadQr.download = "QR_" + nama.replace(/\s+/g, '_') + ".png"; // Nama file saat diunduh

            // Tampilkan modal (hapus class hidden)
            qrModal.classList.remove('hidden');
            qrModal.classList.add('flex'); // Pastikan flex agar centering bekerja

            // Animasi kecil (opsional)
            qrModalImg.classList.add('scale-95');
            setTimeout(() => qrModalImg.classList.remove('scale-95'), 50);
        }

        // Fungsi Tutup Modal
        function closeQrModal() {
            qrModal.classList.add('hidden');
            qrModal.classList.remove('flex');
            qrModalImg.src = ""; // Reset src
        }

        // Tutup jika klik area hitam (backdrop)
        qrModal.addEventListener('click', function(e) {
            if (e.target === qrModal) {
                closeQrModal();
            }
        });

        // Tutup jika tekan tombol ESC
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && !qrModal.classList.contains('hidden')) {
                closeQrModal();
            }
        });
    </script>
}
