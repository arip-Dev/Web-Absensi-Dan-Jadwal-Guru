@model IEnumerable<Latihan1.Services.DapperDb.JadwalRow>
@{
    ViewData["Title"] = "Laporan Lengkap Jadwal";
    string Day(int d) => new[] { "-", "Senin", "Selasa", "Rabu", "Kamis", "Jumat", "Sabtu", "Minggu" }[Math.Clamp(d, 0, 7)];
}
<section class="mx-auto max-w-7xl px-4 py-8">
    <div class="mb-6 flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold tracking-tight">Laporan Lengkap Jadwal</h1>
            <p class="mt-1 text-slate-500">Semua jadwal guru dalam satu halaman</p>
        </div>
        <div class="flex gap-2">
            <a href="/reports/export/pdf" class="rounded-xl bg-blue-600 px-4 py-2 text-white hover:bg-blue-700">Unduh PDF</a>
            <a href="/reports/export/csv" class="rounded-xl border px-4 py-2 text-slate-700 hover:bg-slate-50">Unduh CSV</a>
        </div>
    </div>

    <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white">
        <table class="min-w-full divide-y divide-slate-200">
            <thead class="bg-slate-50">
                <tr class="text-left text-sm font-semibold text-slate-700">
                    <th class="px-6 py-3">Hari</th>
                    <th class="px-6 py-3">Waktu</th>
                    <th class="px-6 py-3">Mapel</th>
                    <th class="px-6 py-3">Guru</th>
                    <th class="px-6 py-3">Kelas / Ruangan</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 text-sm">
                @foreach (var r in Model.OrderBy(x => x.Hari).ThenBy(x => x.Mulai))
                {
                    <tr>
                        <td class="px-6 py-3">@Day(r.Hari)</td>
                        <td class="px-6 py-3">@r.Mulai.ToString(@"hh\:mm") - @r.Selesai.ToString(@"hh\:mm")</td>
                        <td class="px-6 py-3"><span class="rounded-full bg-slate-100 px-3 py-1">@r.Mapel</span></td>
                        <td class="px-6 py-3">@r.GuruNama</td>
                        <td class="px-6 py-3">@r.KelasNama@(string.IsNullOrWhiteSpace(r.Ruangan) ? "" : $" / {r.Ruangan}")</td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td class="px-6 py-6 text-slate-500" colspan="5">Belum ada data.</td></tr>
                }
            </tbody>
        </table>
    </div>
</section>
