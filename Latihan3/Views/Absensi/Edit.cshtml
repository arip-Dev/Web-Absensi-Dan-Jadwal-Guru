@model Latihan3.Models.absensiguru
@{
    ViewData["Title"] = "Edit Absensi";
}

<div class="max-w-lg mx-auto bg-white p-8 rounded-xl shadow border border-gray-200">
    <h1 class="text-2xl font-bold mb-6 text-gray-800">Edit Absensi</h1>

    <form asp-action="Edit" method="post" class="space-y-5">
        <input type="hidden" asp-for="absensiid" />
        <input type="hidden" asp-for="id" />
        <input type="hidden" asp-for="namaguru" />
        <input type="hidden" asp-for="nip" />

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">nama guru</label>
            <input type="text"
                   value="@Model.namaguru"
                   readonly
                   class="w-full rounded-lg border-gray-300 bg-gray-100 text-gray-500 p-2.5 shadow-sm border cursor-not-allowed focus:ring-0" />
            <p class="mt-1 text-xs text-gray-400">guru tidak dapat diubah pada mode edit.</p>
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">tanggal & Waktu</label>
            <input asp-for="tanggal"
                   type="datetime-local"
                   value="@Model.tanggal.ToString("yyyy-MM-ddTHH:mm")"
                   class="w-full rounded-lg border-gray-300 p-2.5 shadow-sm border focus:ring-blue-500 focus:border-blue-500" />
            <span asp-validation-for="tanggal" class="text-xs text-red-500"></span>
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">status</label>
            <select asp-for="status" class="w-full rounded-lg border-gray-300 p-2.5 shadow-sm border focus:ring-blue-500 focus:border-blue-500">
                <option value="Hadir">Hadir</option>
                <option value="Sakit">Sakit</option>
                <option value="Izin">Izin</option>
                <option value="Alpa">Alpa</option>
            </select>
            <span asp-validation-for="status" class="text-xs text-red-500"></span>
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">keterangan</label>
            <textarea asp-for="keterangan" rows="3" class="w-full rounded-lg border-gray-300 p-2.5 shadow-sm border focus:ring-blue-500 focus:border-blue-500"></textarea>
        </div>

        <div class="flex items-center gap-3 pt-4">
            <button type="submit" class="px-5 py-2.5 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 shadow transition">Simpan Perubahan</button>
            <a asp-action="Index" class="px-5 py-2.5 bg-gray-100 text-gray-700 rounded-lg font-medium hover:bg-gray-200 transition">Batal</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}