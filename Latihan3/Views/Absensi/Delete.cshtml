@model Latihan3.Models.absensiguru
@{
    ViewData["Title"] = "Hapus Absensi";
}

<div class="max-w-md mx-auto bg-white p-8 rounded-xl shadow border border-red-100 mt-10">
    <div class="text-center mb-6">
        <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-red-100 mb-4">
            <svg class="h-6 w-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
            </svg>
        </div>
        <h3 class="text-lg leading-6 font-medium text-gray-900">Hapus Data Absensi?</h3>
        <p class="mt-2 text-sm text-gray-500">
            Tindakan ini tidak dapat dibatalkan. Data absensi berikut akan dihapus secara permanen.
        </p>
    </div>

    <div class="bg-gray-50 p-4 rounded-lg mb-6 text-sm border border-gray-200">
        <dl class="grid grid-cols-1 gap-x-4 gap-y-3">
            <div class="flex justify-between border-b pb-2">
                <dt class="font-medium text-gray-500">nama guru</dt>
                <dd class="text-gray-900 font-bold">@Model.namaguru</dd>
            </div>

            <div class="flex justify-between border-b pb-2">
                <dt class="font-medium text-gray-500">nip</dt>
                <dd class="text-gray-900">@(Model.nip ?? "-")</dd>
            </div>

            <div class="flex justify-between border-b pb-2">
                <dt class="font-medium text-gray-500">tanggal</dt>
                <dd class="text-gray-900">@Model.tanggal.ToString("dd MMMM yyyy, HH:mm")</dd>
            </div>

            <div class="flex justify-between border-b pb-2">
                <dt class="font-medium text-gray-500">status</dt>
                <dd class="text-gray-900">
                    <span class="px-2 py-0.5 rounded text-xs font-semibold
                        @(Model.status == "Hadir" ? "bg-green-100 text-green-800" :
                                                    Model.status == "Sakit" ? "bg-yellow-100 text-yellow-800" : "bg-red-100 text-red-800")">
                        @Model.status
                    </span>
                </dd>
            </div>

            <div class="mt-2">
                <dt class="font-medium text-gray-500 mb-1">keterangan</dt>
                <dd class="text-gray-900 bg-white p-2 rounded border border-gray-200 italic">
                    @(string.IsNullOrEmpty(Model.keterangan) ? "-" : Model.keterangan)
                </dd>
            </div>
        </dl>
    </div>

    <form asp-action="Delete" asp-route-id="@Model.absensiid">
        <input type="hidden" name="id" value="@Model.absensiid" />
        <a asp-action="Index" class="px-4 py-2 bg-white border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 font-medium transition">
            Batal
        </a>
        <button type="submit" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 font-medium shadow-sm transition">
            Ya, Hapus
        </button>
    </form>
</div>