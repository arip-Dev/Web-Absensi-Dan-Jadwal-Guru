@model IEnumerable<Latihan3.Models.absensiguru>
@{
    ViewData["Title"] = "Daftar Absensi";
    ViewData["HideNavbar"] = true;
    ViewData["HideFooter"] = true;
}

<div class="min-h-screen bg-gray-50/50 pb-10">

    <nav class="bg-white/80 backdrop-blur-md border-b border-gray-200 px-4 sm:px-6 py-3 sticky top-0 z-30">
        <div class="max-w-7xl mx-auto flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="h-9 w-9 rounded-xl bg-gradient-to-br from-indigo-600 to-violet-600 shadow-lg shadow-indigo-200 grid place-items-center text-white font-bold text-lg">
                    A
                </div>
                <span class="font-bold text-gray-800 tracking-tight text-lg">App<span class="text-indigo-600">Absensi</span></span>
            </div>

            <div class="flex items-center gap-2 sm:gap-3">
                <a class="hidden sm:inline-flex px-3 py-2 bg-white border border-gray-200 text-gray-600 rounded-lg hover:bg-gray-50 hover:text-indigo-600 hover:border-indigo-200 transition-all text-sm font-medium items-center gap-2"
                   href="@Url.Action("Rekapitulasi", "Absensi")">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    Rekapitulasi
                </a>

                <div class="h-6 w-px bg-gray-200 mx-1 hidden sm:block"></div>

                <a asp-controller="Auth" asp-action="BackToAdmin"
                   class="hidden sm:inline-flex text-sm font-medium text-gray-500 hover:text-indigo-600 px-3 py-2 rounded-lg hover:bg-indigo-50 transition-colors items-center gap-2">
                    Back to Admin
                </a>

                <button type="button" onclick="confirmLogout()"
                        class="text-sm font-medium text-white bg-red-600 hover:bg-red-700 px-4 py-2 rounded-lg shadow-sm shadow-red-200 transition-all flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                    </svg>
                    <span class="hidden sm:inline">Keluar</span>
                </button>
            </div>
        </div>
    </nav>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 mt-8">

        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-end gap-4 mb-8">
            <div>
                <h1 class="text-3xl font-bold text-gray-900 tracking-tight">Daftar Kehadiran</h1>
                <p class="text-gray-500 mt-1">Pantau data absensi guru secara <span class="text-indigo-600 font-medium">Real-time</span> hari ini.</p>
            </div>

            <div class="flex items-center gap-3">
                <a class="px-4 py-2.5 bg-white border border-gray-300 text-gray-700 rounded-xl hover:bg-gray-50 hover:border-gray-400 focus:ring-4 focus:ring-gray-100 transition-all flex items-center gap-2 text-sm font-semibold"
                   href="@Url.Action("Create", "Absensi")">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-500" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
                    </svg>
                    Input Manual
                </a>

                <a class="px-4 py-2.5 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 shadow-lg shadow-indigo-200 hover:shadow-indigo-300 focus:ring-4 focus:ring-indigo-100 transition-all flex items-center gap-2 text-sm font-semibold"
                   href="@Url.Action("Scan", "Absensi")">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M3 4a1 1 0 011-1h3a1 1 0 011 1v3a1 1 0 01-1 1H4a1 1 0 01-1-1V4zm2 2V5h1v1H5zM3 13a1 1 0 011-1h3a1 1 0 011 1v3a1 1 0 01-1 1H4a1 1 0 01-1-1v-3zm2 2v-1h1v1H5zM13 3a1 1 0 00-1 1v3a1 1 0 001 1h3a1 1 0 001-1V4a1 1 0 00-1-1h-3zm1 2v1h1V5h-1z" clip-rule="evenodd" />
                        <path d="M11 11a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1h-6a1 1 0 01-1-1v-6zM17 13h-1v-1h1v1zm-2-1h-1v1h1v-1zm-1 2v1h1v-1h-1zm2 1h-1v1h1v-1z" />
                    </svg>
                    Scan QR Code
                </a>
            </div>
        </div>

        @* --- TAMBAHKAN kode ALERT INI --- *@
        @if (TempData["ok"] != null)
        {
            <div class="p-4 mb-4 text-sm text-green-800 rounded-lg bg-green-50 border border-green-200 shadow-sm flex items-center gap-2" role="alert">
                <svg class="flex-shrink-0 w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5Zm3.707 8.207-4 4a1 1 0 0 1-1.414 0l-2-2a1 1 0 0 1 1.414-1.414L9 10.586l3.293-3.293a1 1 0 0 1 1.414 1.414Z" />
                </svg>
                <span class="font-medium">Sukses!</span> @TempData["ok"]
            </div>
        }
        @* -------------------------------- *@

        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">No</th>
                            <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">guru & nip</th>
                            <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Waktu Absen</th>
                            <th scope="col" class="px-6 py-4 text-center text-xs font-bold text-gray-500 uppercase tracking-wider">status</th>
                            <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">keterangan</th>
                            <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Aksi</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="px-6 py-16 text-center">
                                    <div class="flex flex-col items-center justify-center">
                                        <div class="h-24 w-24 bg-gray-50 rounded-full flex items-center justify-center mb-4">
                                            <svg class="h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                                            </svg>
                                        </div>
                                        <h3 class="text-lg font-medium text-gray-900">Belum ada data absensi</h3>
                                        <p class="text-gray-500 text-sm mt-1 max-w-sm">Data kehadiran untuk hari ini belum tersedia. Silakan lakukan Scan QR atau input manual.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            var i = ((ViewBag.CurrentPage - 1) * 10) + 1;
                            foreach (var item in Model)
                            {
                                <tr class="hover:bg-gray-50 transition-colors group">
                                    <td class="px-6 py-4 text-sm text-gray-500 whitespace-nowrap">@i</td>

                                    <td class="px-6 py-4">
                                        <div class="flex flex-col">
                                            <span class="text-sm font-semibold text-gray-900">@item.namaguru</span>
                                            <span class="text-xs text-gray-500 font-mono mt-0.5">nip. @item.nip</span>
                                        </div>
                                    </td>

                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="flex items-center gap-2">
                                            <div class="p-1.5 rounded bg-gray-100 text-gray-500">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                </svg>
                                            </div>
                                            <div class="flex flex-col">
                                                <span class="text-sm font-medium text-gray-900">@item.tanggal.ToString("HH:mm")</span>
                                                <span class="text-xs text-gray-500">@item.tanggal.ToString("dd MMM yyyy")</span>
                                            </div>
                                        </div>
                                    </td>

                                    <td class="px-6 py-4 whitespace-nowrap text-center">
                                        @if (item.status == "Hadir")
                                        {
                                            <span class="px-3 py-1 inline-flex text-xs font-semibold leading-5 rounded-full bg-emerald-100 text-emerald-800 border border-emerald-200 shadow-sm">
                                                Hadir
                                            </span>
                                        }
                                        else if (item.status == "Sakit")
                                        {
                                            <span class="px-3 py-1 inline-flex text-xs font-semibold leading-5 rounded-full bg-amber-100 text-amber-800 border border-amber-200 shadow-sm">
                                                Sakit
                                            </span>
                                        }
                                        else if (item.status == "Izin")
                                        {
                                            <span class="px-3 py-1 inline-flex text-xs font-semibold leading-5 rounded-full bg-blue-100 text-blue-800 border border-blue-200 shadow-sm">
                                                Izin
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="px-3 py-1 inline-flex text-xs font-semibold leading-5 rounded-full bg-rose-100 text-rose-800 border border-rose-200 shadow-sm">
                                                @item.status
                                            </span>
                                        }
                                    </td>

                                    <td class="px-6 py-4">
                                        <p class="text-sm text-gray-600 truncate max-w-xs" title="@item.keterangan">
                                            @(string.IsNullOrEmpty(item.keterangan) ? "-" : item.keterangan)
                                        </p>
                                    </td>

                                    <td class="px-6 py-4 whitespace-nowrap text-left text-sm font-medium">
                                        <div class="flex items-center gap-2">
                                            <a asp-action="Edit" asp-route-id="@item.absensiid"
                                               class="p-2 bg-white border border-gray-200 rounded-lg text-indigo-600 hover:bg-indigo-50 hover:border-indigo-200 transition-all shadow-sm"
                                               title="Edit Data">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                                                </svg>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.absensiid"
                                               class="p-2 bg-white border border-gray-200 rounded-lg text-rose-600 hover:bg-rose-50 hover:border-rose-200 transition-all shadow-sm"
                                               title="Hapus Data">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                                </svg>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                i++;
                            }
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.Any())
            {
                <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 flex items-center justify-between">
                    <div class="text-sm text-gray-500">
                        Halaman <span class="font-bold text-gray-900">@ViewBag.CurrentPage</span> dari <span class="font-bold text-gray-900">@ViewBag.TotalPages</span>
                    </div>
                    <div class="flex gap-2">
                        <a href="@(ViewBag.CurrentPage > 1 ? Url.Action("Index", new { page = ViewBag.CurrentPage - 1 }) : "#")"
                           class="px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium transition-colors @(ViewBag.CurrentPage > 1 ? "bg-white text-gray-700 hover:bg-gray-50 hover:text-indigo-600" : "bg-gray-100 text-gray-400 cursor-not-allowed")">
                            Sebelumnya
                        </a>

                        <a href="@(ViewBag.CurrentPage<ViewBag.TotalPages? Url.Action("Index", new { page = ViewBag.CurrentPage + 1 }) : "#")"
                           class="px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium transition-colors @(ViewBag.CurrentPage < ViewBag.TotalPages ? "bg-white text-gray-700 hover:bg-gray-50 hover:text-indigo-600" : "bg-gray-100 text-gray-400 cursor-not-allowed")">
                            Selanjutnya
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function confirmLogout() {
        Swal.fire({
            title: 'Konfirmasi Keluar',
            text: "Apakah Anda yakin ingin mengakhiri sesi ini?",
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#4f46e5', // Indigo-600 matching theme
            cancelButtonColor: '#9ca3af',  // Gray-400
            confirmButtonText: 'Ya, Keluar',
            cancelButtonText: 'Batal',
            reverseButtons: true,
            customClass: {
                popup: 'rounded-xl',
                confirmButton: 'rounded-lg px-4 py-2',
                cancelButton: 'rounded-lg px-4 py-2'
            }
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Logout", "Auth")';
            }
        })
    }
</script>